# ─────────────────────────────────────────────────────────────────────────────
# alfred frontend (Next.js) environment — TEMPLATE (safe to commit).
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL, e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (client-safe) key — new Supabase format `sb_publishable_...`
# (replaces the legacy `anon` JWT). Exposed to the browser; safe with RLS on.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret key — SERVER-SIDE ONLY. New Supabase format `sb_secret_...`
# (replaces the legacy `service_role` JWT). Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Legacy service_role JWT (optional) — SERVER-SIDE ONLY. Only needed for tooling
# that still expects a JWT-format service key.
SUPABASE_SERVICE_ROLE_JWT=

# Shared secret the external/Siri capture ingress must present to POST /api/items.
# Generate with: openssl rand -hex 32
INGEST_API_KEY=

# Postgres connection string — used ONLY for applying migrations and generating types
# (not by the app at runtime).
#
# Use the **Session pooler** URI (Database → Connection string → Session pooler).
# It is IPv4-proxied for free, so it works from any network. Format:
#   postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
#
# Avoid the **Direct connection** URI (db.<project-ref>.supabase.co) unless you are on
# an IPv6 network — that host is IPv6-only and will fail DNS/connect on IPv4-only
# machines. The Session pooler is the recommended default going forward.
#
# If the password contains special chars (#, @, etc.), quote the whole value and
# percent-encode them (e.g. # -> %23).
DATABASE_URL=

# Vercel access token (OPTIONAL) — used ONLY for CLI deploys (`vercel --prod`), never by
# the app at runtime. Create at Vercel → Account Settings → Tokens, scoped to the team the
# project lives under. With this set, `set -a; . .env.local; set +a; vercel --prod` deploys
# without an interactive login. Server-only secret — keep it out of git (lives in .env.local).
VERCEL_TOKEN=
