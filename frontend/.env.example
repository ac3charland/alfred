# ─────────────────────────────────────────────────────────────────────────────
# alfred frontend (Next.js) environment — TEMPLATE (safe to commit).
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL, e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (client-safe) key — new Supabase format `sb_publishable_...`
# (replaces the legacy `anon` JWT). Exposed to the browser; safe with RLS on.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret key — SERVER-SIDE ONLY. New Supabase format `sb_secret_...`
# (replaces the legacy `service_role` JWT). Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Legacy service_role JWT (optional) — SERVER-SIDE ONLY. Only needed for tooling
# that still expects a JWT-format service key.
SUPABASE_SERVICE_ROLE_JWT=

# Shared secret the external/Siri capture ingress must present to POST /api/items.
# Generate with: openssl rand -hex 32
INGEST_API_KEY=

# Postgres connection string — used ONLY for applying migrations and generating types
# (not by the app at runtime). Use the Direct connection URI (Database → Connection
# string → Direct connection). If the password contains special chars (#, @, etc.),
# quote the whole value and percent-encode them (e.g. # -> %23). See README §3.
DATABASE_URL=
