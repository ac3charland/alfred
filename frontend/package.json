{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --fix --cache --cache-location .eslintcache .",
    "format": "prettier --write --cache .",
    "test": "jest --passWithNoTests",
    "mutation": "stryker run",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "serve:storybook": "http-server storybook-static -p 6006 --silent",
    "setup:chromium": "node scripts/setup-chromium.mjs",
    "screenshot": "node scripts/screenshot.mjs",
    "test:storybook": "node scripts/snapshot-docker.mjs",
    "test:storybook:update": "node scripts/snapshot-docker.mjs --update",
    "test:storybook:linux": "npm run setup:chromium && npm run storybook:build && concurrently --kill-others --success=first \"http-server storybook-static -p 6006 --silent\" \"wait-on http://127.0.0.1:6006 && test-storybook --ci --url http://127.0.0.1:6006\"",
    "test:storybook:linux:update": "npm run setup:chromium && npm run storybook:build && concurrently --kill-others --success=first \"http-server storybook-static -p 6006 --silent\" \"wait-on http://127.0.0.1:6006 && test-storybook --url http://127.0.0.1:6006 -u\"",
    "test:e2e": "node scripts/setup-chromium.mjs && playwright test",
    "check:fast": "npm run typecheck && npm run lint && npm run format && npm run test",
    "check:slow": "npm run test:storybook && npm run test:e2e"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.7",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/nextjs": "^10.4.3",
    "@storybook/test-runner": "^0.24.4",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/jest-image-snapshot": "^6.4.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.3",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^65.0.1",
    "globals": "^14.0.0",
    "http-server": "^14.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-image-snapshot": "^6.5.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.61.0",
    "wait-on": "^9.0.10"
  }
}
